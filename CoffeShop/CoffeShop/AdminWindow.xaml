<Window x:Class="CoffeeShop.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Администратор" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Grid Grid.Row="0" Background="#4A2C2A">
            <TextBlock Text="Управление сетью кофеен — Администратор"
                       Foreground="White" FontSize="16" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="15,0,0,0"/>
        </Grid>

        <!-- Вкладки -->
        <TabControl Grid.Row="1" Margin="10">

            <!-- Вкладка Товары -->
            <TabItem Header="Товары">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>

                    <!-- Поиск и фильтрация -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                        <TextBox x:Name="ProductSearchBox" Width="200" Height="30"
                                 Padding="5" Margin="0,0,10,0"
                                 TextChanged="ProductSearchBox_TextChanged"/>
                        <ComboBox x:Name="CategoryFilter" Width="150" Height="30"
                                  Margin="0,0,10,0"
                                  SelectionChanged="CategoryFilter_SelectionChanged"/>
                        <Button Content="Сбросить фильтр" Height="30" Padding="10,0"
                                Click="ResetProductFilter_Click"/>
                    </StackPanel>

                    <!-- Таблица товаров -->
                    <DataGrid x:Name="ProductsGrid" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="120"/>
                            <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="100"/>
                            <DataGridTextColumn Header="Единица" Binding="{Binding Unit}" Width="80"/>
                            <DataGridTextColumn Header="Кофейня" Binding="{Binding Coffeehouse.Name}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Кнопки -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5">
                        <Button Content="Добавить" Height="35" Padding="15,0"
                                Margin="0,0,10,0" Background="#4A2C2A" Foreground="White"
                                BorderThickness="0" Click="AddProduct_Click"/>
                        <Button Content="Редактировать" Height="35" Padding="15,0"
                                Margin="0,0,10,0" Background="#4A2C2A" Foreground="White"
                                BorderThickness="0" Click="EditProduct_Click"/>
                        <Button Content="Удалить" Height="35" Padding="15,0"
                                Background="#8B0000" Foreground="White"
                                BorderThickness="0" Click="DeleteProduct_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка Сотрудники -->
            <TabItem Header="Сотрудники">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="EmployeesGrid" Grid.Row="0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="200"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="130"/>
                            <DataGridTextColumn Header="Роль" Binding="{Binding Role.Name}" Width="120"/>
                            <DataGridTextColumn Header="Кофейня" Binding="{Binding Coffeehouse.Name}" Width="150"/>
                            <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
                        <Button Content="Добавить" Height="35" Padding="15,0"
                                Margin="0,0,10,0" Background="#4A2C2A" Foreground="White"
                                BorderThickness="0" Click="AddEmployee_Click"/>
                        <Button Content="Редактировать" Height="35" Padding="15,0"
                                Margin="0,0,10,0" Background="#4A2C2A" Foreground="White"
                                BorderThickness="0" Click="EditEmployee_Click"/>
                        <Button Content="Удалить" Height="35" Padding="15,0"
                                Background="#8B0000" Foreground="White"
                                BorderThickness="0" Click="DeleteEmployee_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка Кофейни -->
            <TabItem Header="Кофейни">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="CoffeehousesGrid" Grid.Row="0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="250"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
                        <Button Content="Добавить" Height="35" Padding="15,0"
                                Margin="0,0,10,0" Background="#4A2C2A" Foreground="White"
                                BorderThickness="0" Click="AddCoffeehouse_Click"/>
                        <Button Content="Редактировать" Height="35" Padding="15,0"
                                Margin="0,0,10,0" Background="#4A2C2A" Foreground="White"
                                BorderThickness="0" Click="EditCoffeehouse_Click"/>
                        <Button Content="Удалить" Height="35" Padding="15,0"
                                Background="#8B0000" Foreground="White"
                                BorderThickness="0" Click="DeleteCoffeehouse_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка Отчёты -->
            <TabItem Header="Отчёты">
                <StackPanel Margin="20">
                    <TextBlock Text="Выгрузка отчёта о продажах" FontSize="16"
                               FontWeight="Bold" Margin="0,0,0,20"/>

                    <TextBlock Text="Выберите месяц:" Margin="0,0,0,5"/>
                    <ComboBox x:Name="MonthComboBox" Width="200"
                              HorizontalAlignment="Left" Height="30"
                              Margin="0,0,0,15"/>

                    <TextBlock Text="Выберите год:" Margin="0,0,0,5"/>
                    <ComboBox x:Name="YearComboBox" Width="200"
                              HorizontalAlignment="Left" Height="30"
                              Margin="0,0,0,20"/>

                    <Button Content="Выгрузить в Excel" Height="40" Width="200"
                            HorizontalAlignment="Left"
                            Background="#4A2C2A" Foreground="White"
                            BorderThickness="0" FontSize="14"
                            Click="ExportToExcel_Click"/>
                </StackPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
    