<Window x:Class="CoffeeShop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="300" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#F5F5F5">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">

            <TextBlock Text="Управление сетью кофеен"
                       FontSize="18" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"
                       Foreground="#4A2C2A"/>

            <TextBlock Text="Логин" Margin="0,0,0,5" Foreground="#333"/>
            <TextBox x:Name="LoginBox"
                     Height="35" Padding="8"
                     FontSize="14"
                     Margin="0,0,0,15"/>

            <TextBlock Text="Пароль" Margin="0,0,0,5" Foreground="#333"/>
            <PasswordBox x:Name="PasswordBox"
                         Height="35" Padding="8"
                         FontSize="14"
                         Margin="0,0,0,20"/>

            <Button Content="Войти"
                    Height="40"
                    FontSize="14"
                    Background="#4A2C2A"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="LoginButton_Click"/>

            <TextBlock x:Name="ErrorText"
                       Foreground="Red"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"
                       FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>
    